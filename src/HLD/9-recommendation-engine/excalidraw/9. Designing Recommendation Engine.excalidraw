    },
    {
      "id": "1s2XjZRmCIFQQjq9HShPg",
      "type": "text",
      "x": 2288.5590756293877,
      "y": 53837.80521209649,
      "width": 1177,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bUC",
      "roundness": null,
      "seed": 1220346594,
      "version": 322,
      "versionNonce": 1045639065,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777046653737,
      "link": null,
      "locked": false,
      "text": "Finanical Transactions are risky and prone to frauds. Banks have to deploy fraud detection system, that can\n\n- Detect fraud in realtime.\n- Block the transaction.\n    - Inform a customer support executive. (to take consent)\n    - Block the transaction.\n    - Inform a customer support executive.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Finanical Transactions are risky and prone to frauds. Banks have to deploy fraud detection system, that can\n\n- Detect fraud in realtime.\n- Block the transaction.\n    - Inform a customer support executive. (to take consent)\n    - Block the transaction.\n    - Inform a customer support executive.",
      "autoResize": true,
      "lineHeight": 1.25
    },
