    {
      "id": "orkHBnMFcl0LO04atnC58",
      "type": "text",
      "x": 2284.8262842622526,
      "y": 56854.1014722237,
      "width": 893.19970703125,
      "height": 35,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bVo",
      "roundness": null,
      "seed": 718147518,
      "version": 161,
      "versionNonce": 543417497,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777046669070,
      "link": null,
      "locked": false,
      "text": "Fraud Detection Algorithm (Decision trees / Random Forest)",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Fraud Detection Algorithm (Decision trees / Random Forest)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "BzOLTeJa0BepuxWbaIyEU",
      "type": "text",
      "x": 2301.177252809576,
      "y": 56934.79343313139,
      "width": 1067,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bVp",
      "roundness": null,
      "seed": 913318690,
      "version": 340,
      "versionNonce": 1940721015,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777046669070,
      "link": null,
      "locked": false,
      "text": "Fraud Detection Service use multiple parameters to judge if current transactions is found or not.\nWe generate a lot of decision tree (random forests) from the training data and train the model.\nEvery transactions is classified into either Fraudulent or Non Fraudlent.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Fraud Detection Service use multiple parameters to judge if current transactions is found or not.\nWe generate a lot of decision tree (random forests) from the training data and train the model.\nEvery transactions is classified into either Fraudulent or Non Fraudlent.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "5N1EM1wlQnHo-oGR--bZ2",
      "type": "text",
      "x": 2300.454443969467,
      "y": 57053.25663910498,
      "width": 649,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bVq",
      "roundness": null,
      "seed": 821758078,
      "version": 68,
      "versionNonce": 864938361,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777046669070,
      "link": null,
      "locked": false,
      "text": "New txn is classified across all and majority is considered",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "New txn is classified across all and majority is considered",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "vusNKNVMyzQNFn5a1B4pr",
      "type": "text",
      "x": 2297.8110287827826,
      "y": 57124.59948503633,
      "width": 385,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bVr",
      "roundness": null,
      "seed": 1126562082,
      "version": 158,
      "versionNonce": 62539415,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777046669070,
      "link": null,
      "locked": false,
      "text": "So we will have multiple tree\n- One tree for loc + time\n- Sec tree for loc + bank\n- Third tree for time + user + bank\n... etc",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "So we will have multiple tree\n- One tree for loc + time\n- Sec tree for loc + bank\n- Third tree for time + user + bank\n... etc",
      "autoResize": true,
      "lineHeight": 1.25
    },
