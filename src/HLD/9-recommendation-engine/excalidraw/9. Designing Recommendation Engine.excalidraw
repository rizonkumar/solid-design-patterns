    {
      "id": "1aPi28vZvB0qnJXlWR39l",
      "type": "text",
      "x": 3233.771032919727,
      "y": 56342.52741905373,
      "width": 561,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bVm",
      "roundness": null,
      "seed": 2026422462,
      "version": 237,
      "versionNonce": 648877625,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777046670387,
      "link": null,
      "locked": false,
      "text": "Fraud Detection is a simple HTTP based service that\n\n1. gets transaction and request details (over HTTP)\n2. it returns if it is fraudulent or not.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Fraud Detection is a simple HTTP based service that\n\n1. gets transaction and request details (over HTTP)\n2. it returns if it is fraudulent or not.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Bhavfjv_xmyXgnLCuNXH3",
      "type": "text",
      "x": 2310.1813857892203,
      "y": 56753.066383427264,
      "width": 638,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bVn",
      "roundness": null,
      "seed": 877118626,
      "version": 95,
      "versionNonce": 220672087,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777046669070,
      "link": null,
      "locked": false,
      "text": "Note: Fraud detectoin service should respond within 200ms.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Note: Fraud detectoin service should respond within 200ms.",
