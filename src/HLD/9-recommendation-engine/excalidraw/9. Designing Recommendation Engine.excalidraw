      "seed": 277824601,
      "version": 84,
      "versionNonce": 1415949431,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777005507397,
      "link": null,
      "locked": false,
      "text": "- Cluster the content (products, videos, articles) into groups based on their features, such as title,\n description, or type\n\n- When an item is interacted with, the system picks other items from the same cluster to recommend.\n\nFIG 1.1",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Cluster the content (products, videos, articles) into groups based on their features, such as title,\n description, or type\n\n- When an item is interacted with, the system picks other items from the same cluster to recommend.\n\nFIG 1.1",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "A-PjWESijVKNGe_kU8yQy",
