      "updated": 1777046691468,
      "link": null,
      "locked": false,
      "text": "We write a job that periodically processes the data from the CS database extracts the fraud trnx, communication\nsummary, details shared on ticket. put them in a blob storage like S3.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We write a job that periodically processes the data from the CS database extracts the fraud trnx, communication\nsummary, details shared on ticket. put them in a blob storage like S3.",
      "autoResize": true,
      "lineHeight": 1.25
    },
