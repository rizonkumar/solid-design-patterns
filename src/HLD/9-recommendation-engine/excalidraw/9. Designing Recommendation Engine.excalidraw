    },
    {
      "id": "LR4Xs70vF8DQqj1RVMVtA",
      "type": "text",
      "x": 2329.511868700497,
      "y": 64598.15921559101,
      "width": 781,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fd7e14",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bZZ",
      "roundness": null,
      "seed": 568265625,
      "version": 531,
      "versionNonce": 796312215,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777005880115,
      "link": null,
      "locked": false,
      "text": "A common way to determine if two items are similar is cosine similarity",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A common way to determine if two items are similar is cosine similarity",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "5-H2VEOyJhgwAq5gMSLUo",
      "type": "text",
      "x": 2277.8566237152536,
      "y": 62940.659971146815,
      "width": 792,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fd7e14",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bZa",
      "roundness": null,
      "seed": 1113309337,
      "version": 38,
      "versionNonce": 277137559,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1777005309165,
      "link": null,
      "locked": false,
      "text": "Items are converted into mathematical vectors in an n-dimensional space,\nwhere each dimension represents a feature (like tokens in a product\ndescription)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Items are converted into mathematical vectors in an n-dimensional space, where each dimension represents a feature (like tokens in a product description)",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "-EqAgkgRN2Zv-XlXiRGFc",
      "type": "text",
      "x": 2668.3566237152536,
      "y": 63050.659971146815,
      "width": 11,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fd7e14",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bZb",
      "roundness": null,
      "seed": 1924198775,
      "version": 38,
      "versionNonce": 1031467097,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1777005309165,
      "link": null,
      "locked": false,
      "text": ".",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": ".",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "r_cSQ45gw8yX1sHotKZv6",
      "type": "text",
      "x": 2283.3566237152536,
      "y": 63048.159971146815,
      "width": 781,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fd7e14",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bZc",
      "roundness": null,
      "seed": 36324729,
      "version": 38,
      "versionNonce": 539860407,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1777005309165,
      "link": null,
      "locked": false,
      "text": "The angle between two item vectors dictates their similarity: a smaller\nangle means they are closer and highly similar (cosine approaches 1),\nwhile a larger angle (approaching 90 degrees) means they are dissimilar\n(cosine approaches 0)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The angle between two item vectors dictates their similarity: a smaller angle means they are closer and highly similar (cosine approaches 1), while a larger angle (approaching 90 degrees) means they are dissimilar (cosine approaches 0)",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "Wl3EeZKG09nVLLJ9DEq6u",
      "type": "text",
      "x": 2323.941311870774,
      "y": 64671.22603597954,
      "width": 1463,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fd7e14",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bZd",
      "roundness": null,
      "seed": 291259671,
      "version": 471,
      "versionNonce": 1712252793,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777046034013,
      "link": null,
      "locked": false,
      "text": "- Items are converted into mathematical vectors in an n-dimensional space, where each dimension represents \n  a feature (like tokens in a product description)\n\n- The angle between two item vectors dictates their similarity: a smaller angle means they are closer and\n  highly similar (cosine approaches 1), while a larger angle (approaching 90 degrees) means they are dissimilar (cosine approaches 0)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Items are converted into mathematical vectors in an n-dimensional space, where each dimension represents \n  a feature (like tokens in a product description)\n\n- The angle between two item vectors dictates their similarity: a smaller angle means they are closer and\n  highly similar (cosine approaches 1), while a larger angle (approaching 90 degrees) means they are dissimilar (cosine approaches 0)",
      "autoResize": true,
      "lineHeight": 1.25
    },
