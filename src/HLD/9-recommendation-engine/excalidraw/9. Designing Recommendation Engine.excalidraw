    {
      "id": "KMiM1bKa_zMjssHkrpWRM",
      "type": "text",
      "x": 2388.2380910532743,
      "y": 62646.17339691452,
      "width": 1122,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fd7e14",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
