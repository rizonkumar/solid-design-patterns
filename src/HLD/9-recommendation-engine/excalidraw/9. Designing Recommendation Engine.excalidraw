    {
      "id": "azbfpzY0IuBLKkcRlFRs-",
      "type": "text",
      "x": 2330.190412539682,
      "y": 65028.67940443642,
      "width": 1210,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fd7e14",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bbR",
      "roundness": null,
      "seed": 41329881,
      "version": 144,
      "versionNonce": 837836345,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777046109412,
      "link": null,
      "locked": false,
      "text": "Concept: Recommends items that other, similar users have purchased. \nIf User A and User B are similar, and User A bought an iPhone, the system will recommend an iPhone to User B. \nThis encourages exploration by suggesting new things the user hasn't explicitly shown interest in",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Concept: Recommends items that other, similar users have purchased. \nIf User A and User B are similar, and User A bought an iPhone, the system will recommend an iPhone to User B. \nThis encourages exploration by suggesting new things the user hasn't explicitly shown interest in",
      "autoResize": true,
      "lineHeight": 1.25
    },
