      "verticalAlign": "top",
      "containerId": null,
      "originalText": "S3",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "KgWzFcrM8eBpud-3Y7su-",
      "type": "text",
      "x": 2637.7012373209795,
      "y": 58341.228743247826,
      "width": 946,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bWo",
      "roundness": null,
      "seed": 273306274,
      "version": 116,
      "versionNonce": 2008833239,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777046691468,
      "link": null,
      "locked": false,
      "text": "The amount of data moved from DB to S3 is huge and hence we need distributed computing",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The amount of data moved from DB to S3 is huge and hence we need distributed computing",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Ev0QBQd0KAyEwcM72DfjD",
      "type": "text",
      "x": 2634.9390749677054,
      "y": 58401.268343259464,
      "width": 968,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bWp",
      "roundness": null,
      "seed": 1580102818,
      "version": 116,
      "versionNonce": 912637977,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777046691468,
      "link": null,
      "locked": false,
      "text": "One machine reading from S3 and tranforming and writing to S3 will slow down the system.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "One machine reading from S3 and tranforming and writing to S3 will slow down the system.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ec7iNMEHnMhRK6o-0yVX_",
      "type": "text",
      "x": 2328.2099807471354,
      "y": 58544.03954598949,
      "width": 748,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bWq",
      "roundness": null,
      "seed": 1405586878,
      "version": 210,
      "versionNonce": 468232695,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777046691468,
      "link": null,
      "locked": false,
      "text": "To train our model, we need data, the detatils about the transaction\n- who sent to whom\n- from which IP location, region, currency, etc\n\nAll this is present in transaction DB.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "To train our model, we need data, the detatils about the transaction\n- who sent to whom\n- from which IP location, region, currency, etc\n\nAll this is present in transaction DB.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "MJ0tVzBjgdzwDKCL0sGhe",
      "type": "text",
      "x": 2329.691738869359,
      "y": 58729.33675507174,
      "width": 935,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bWr",
      "roundness": null,
      "seed": 407567202,
      "version": 107,
      "versionNonce": 1931958233,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777046697578,
      "link": null,
      "locked": false,
      "text": "Similar to moving data from CS DB to S3 we need spark, we will move data from FIG 1.5",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Similar to moving data from CS DB to S3 we need spark, we will move data from FIG 1.5",
      "autoResize": true,
      "lineHeight": 1.25
    },
