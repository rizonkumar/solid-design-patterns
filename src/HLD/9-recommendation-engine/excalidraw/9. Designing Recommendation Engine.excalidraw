      "link": null,
      "locked": false,
      "text": "34. Designing a Fraud Detection system",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "34. Designing a Fraud Detection system",
      "autoResize": true,
