    {
      "id": "huVJLTvUcZqyzHnrcBxoz",
      "type": "text",
      "x": 2366.1161414905696,
      "y": 59358.16269842811,
      "width": 715,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
