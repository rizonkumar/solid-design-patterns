    {
      "id": "rRNkuAMIzC1v5FruWLdGa",
      "type": "text",
      "x": 2597.0140372969713,
      "y": 61347.35492588698,
      "width": 726,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#fd7e14",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bZC",
      "roundness": null,
      "seed": 567510009,
      "version": 143,
      "versionNonce": 1322993497,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777004831720,
      "link": null,
      "locked": false,
      "text": "Remember how many times you just click on a recommended video/song\nor purchase a book recommended by Amazon.",
      "fontSize": 20,
      "fontFamily": 8,
