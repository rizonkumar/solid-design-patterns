      "seed": 1097726882,
      "version": 133,
      "versionNonce": 1912328825,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777046636069,
      "link": null,
      "locked": false,
      "text": "Now that all data we want to train the model is in S3\nwe use only distributed ML processing libraris to built the model",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Now that all data we want to train the model is in S3\nwe use only distributed ML processing libraris to built the model",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "XRx42z4S5ddYbDrpKmJgS",
      "type": "text",
      "x": 2371.826331327431,
      "y": 59446.71710718204,
      "width": 638,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bXl",
      "roundness": null,
      "seed": 70587134,
      "version": 202,
      "versionNonce": 440102295,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777046636069,
      "link": null,
      "locked": false,
      "text": "E.g. Using SPark + MLlib to\ntrain our \"Decision Tree\" and put the model back\nin S3. Model is just a file holding the serialized version\nof decision tree.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "E.g. Using SPark + MLlib to\ntrain our \"Decision Tree\" and put the model back\nin S3. Model is just a file holding the serialized version\nof decision tree.",
      "autoResize": true,
      "lineHeight": 1.25
    },
