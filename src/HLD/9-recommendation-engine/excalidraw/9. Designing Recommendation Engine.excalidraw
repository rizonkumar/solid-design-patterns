    {
      "id": "ndiiIlHuv5HxODK7Ut3rz",
      "type": "text",
      "x": 2288.5590756293864,
      "y": 54572.684637152895,
      "width": 1177,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bUS",
      "roundness": null,
      "seed": 163718434,
      "version": 195,
      "versionNonce": 1819842903,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777046656885,
      "link": null,
      "locked": false,
      "text": "When a user initiates the transaction, the bank makes an entry but before proceeding furtherm it check for \na potential fraud, if not a fraud: allow the transaction",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When a user initiates the transaction, the bank makes an entry but before proceeding furtherm it check for \na potential fraud, if not a fraud: allow the transaction",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "udkJt0sk3q__Wi-NJm1F7",
      "type": "text",
      "x": 2285.0121493925653,
      "y": 54651.987092753436,
      "width": 495,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bUT",
      "roundness": null,
      "seed": 773629730,
      "version": 187,
      "versionNonce": 401194489,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777046655685,
      "link": null,
      "locked": false,
      "text": "Otherwise:\n- Hold the transaction\n- Involve the executive\n- call the customer and confirm\n- if customer says yes: allow the transaction\n- else: abort",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Otherwise:\n- Hold the transaction\n- Involve the executive\n- call the customer and confirm\n- if customer says yes: allow the transaction\n- else: abort",
      "autoResize": true,
      "lineHeight": 1.25
