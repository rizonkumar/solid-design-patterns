      "updated": 1775787664090,
      "link": null,
      "locked": false,
      "text": "People swipe left or right to inidicate interest.\nWe do not need a seperate DB to hold this info and we leverage\nfeed databse and just add \"is_intersted\" in each acton",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "People swipe left or right to inidicate interest.\nWe do not need a seperate DB to hold this info and we leverage\nfeed databse and just add \"is_intersted\" in each acton",
      "autoResize": true,
      "lineHeight": 1.25
    },
