      "isDeleted": false,
      "boundElements": [],
      "updated": 1775786513549,
      "link": null,
      "locked": false,
      "text": "Feed dd can potentially explode (n x n) (user x user) and will require decent storage.\nFor each user, the DB holds Feed items\nFetch feed item -> Profile information that user has not seen before",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Feed dd can potentially explode (n x n) (user x user) and will require decent storage.\nFor each user, the DB holds Feed items\nFetch feed item -> Profile information that user has not seen before",
      "autoResize": true,
      "lineHeight": 1.25
    },
