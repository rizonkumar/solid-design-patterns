      "boundElements": [],
      "updated": 1775751646368,
      "link": null,
      "locked": false,
      "text": "Design Feed for Tiner and feature to swipe left or right. For a great user experience, a user should not be shown a profile\nthat he/she already swiped.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Design Feed for Tiner and feature to swipe left or right. For a great user experience, a user should not be shown a profile\nthat he/she already swiped.",
      "autoResize": true,
      "lineHeight": 1.25
    },
