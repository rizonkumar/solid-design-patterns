      "isDeleted": false,
      "boundElements": [],
      "updated": 1775752174299,
      "link": null,
      "locked": false,
      "text": "so the data stored will be\n    key -> userId\n    value -> lat,long",
      "fontSize": 20,
      "fontFamily": 8,
