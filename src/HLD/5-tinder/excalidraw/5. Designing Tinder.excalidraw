    },
    {
      "id": "WElAfWQIBTBPW7M3_XrxR",
      "type": "text",
      "x": 1582.2091224439873,
      "y": 31976.99495806476,
      "width": 1122,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bIX",
      "roundness": null,
      "seed": 716593973,
      "version": 322,
      "versionNonce": 1094274613,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775786393031,
      "link": null,
      "locked": false,
      "text": "Behaviour: Generate feed when user is about to exhause the current one\n\nFrontend: Will make an API call to trigger population of the feed. -> User swiper faster -> BETTER UX.\n                                    OR\nBackend: Maintain a feed counter in backend and check everytime user swipes -> SLOW UX.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Behaviour: Generate feed when user is about to exhause the current one\n\nFrontend: Will make an API call to trigger population of the feed. -> User swiper faster -> BETTER UX.\n                                    OR\nBackend: Maintain a feed counter in backend and check everytime user swipes -> SLOW UX.",
      "autoResize": true,
      "lineHeight": 1.25
    },
