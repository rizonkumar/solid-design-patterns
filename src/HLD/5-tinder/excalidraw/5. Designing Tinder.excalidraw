      "isDeleted": false,
      "boundElements": [],
      "updated": 1775840984167,
      "link": null,
      "locked": false,
      "text": "We use Redis + Periodic persist to store swipe information\nBloom filter is consulted before adding any item to feed , \nfig 1.4",
