      "versionNonce": 1355376603,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775752128719,
      "link": null,
      "locked": false,
      "text": "Amount of data is not the concern, but the query to store and get is the concern hence we use Redix.\nHence we are sharding.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Amount of data is not the concern, but the query to store and get is the concern hence we use Redix.\nHence we are sharding.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "dR73N7nnJWd8MzsWQir0v",
      "type": "text",
      "x": 2723.679411154321,
      "y": 30275.399643290675,
