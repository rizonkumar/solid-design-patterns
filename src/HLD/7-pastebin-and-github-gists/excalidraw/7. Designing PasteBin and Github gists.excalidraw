      "groupIds": [],
      "frameId": null,
      "index": "bS3",
      "roundness": null,
      "seed": 1311091407,
      "version": 139,
      "versionNonce": 1315128385,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776647846375,
      "link": null,
      "locked": false,
      "text": "There might be some files that are frequently accessed, so should we cache\nthem to improve user perceived latenlt?",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "There might be some files that are frequently accessed, so should we cache\nthem to improve user perceived latenlt?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "W40v8aKXXPMAW2X1CIbev",
      "type": "text",
      "x": 2254.987485044924,
      "y": 50647.58767013694,
      "width": 605,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bS4",
      "roundness": null,
      "seed": 1286952079,
      "version": 76,
      "versionNonce": 718488623,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776647869826,
      "link": null,
      "locked": false,
      "text": "We are for sure templated to do so? but is it worth it?",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We are for sure templated to do so? but is it worth it?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ohj1DKhWzqrhaAVoo0q1O",
      "type": "text",
      "x": 2262.983578794924,
      "y": 50709.84450607444,
      "width": 275,
      "height": 25,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bS5",
      "roundness": null,
      "seed": 538099201,
      "version": 47,
      "versionNonce": 1684592641,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776647895768,
      "link": null,
      "locked": false,
      "text": "\"frequently\" -> how much?",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\"frequently\" -> how much?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "LYp9D4lraVARN8OPzCXzI",
      "type": "text",
      "x": 2704.393735044924,
      "y": 50702.18825607444,
      "width": 539,
      "height": 50,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bS6",
      "roundness": null,
      "seed": 234802383,
      "version": 134,
      "versionNonce": 1022490127,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776647934255,
      "link": null,
      "locked": false,
      "text": "- Cache stores in RAM (10 MB is huge for a cache)\n- Pretty expensive ",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Cache stores in RAM (10 MB is huge for a cache)\n- Pretty expensive ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "nnX-aDXx82N_rnAKFpsvE",
      "type": "text",
      "x": 2250.311703794924,
      "y": 50799.99294357444,
      "width": 1100,
      "height": 25,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bS7",
      "roundness": null,
      "seed": 1123179631,
      "version": 164,
      "versionNonce": 1421040527,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776648032574,
      "link": null,
      "locked": false,
      "text": "If the frequency is not \"huge\", it does not make sense to cache the file. As a one word answer: NO!!",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If the frequency is not \"huge\", it does not make sense to cache the file. As a one word answer: NO!!",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Wt_ybpvWUDqbZtSdMj0HY",
      "type": "text",
      "x": 2250.866391294924,
      "y": 50863.40700607444,
      "width": 1034,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bS8",
      "roundness": null,
      "seed": 206823599,
      "version": 123,
      "versionNonce": 1111736833,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776648016209,
      "link": null,
      "locked": false,
      "text": "I would rather prefer to serve 10 request from S3 than add an expensive cache and maintain it.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "I would rather prefer to serve 10 request from S3 than add an expensive cache and maintain it.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "JM54Szi32gDF5Uc5RKj_w",
      "type": "text",
      "x": 2250.905453794924,
      "y": 50921.82521896507,
      "width": 891,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bS9",
      "roundness": null,
      "seed": 582828591,
      "version": 113,
      "versionNonce": 705396033,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776648133554,
      "link": null,
      "locked": false,
      "text": "But he open to understanding user behaviour and access pattern based on analytics",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "But he open to understanding user behaviour and access pattern based on analytics",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Bbs_4qMe1t9cCtL_VtNtR",
      "type": "text",
      "x": 2254.948437803713,
      "y": 50995.758202363504,
      "width": 153.99993896484375,
      "height": 35,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bSA",
      "roundness": null,
      "seed": 1690922497,
      "version": 1016,
      "versionNonce": 1204598799,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776648234553,
      "link": null,
      "locked": false,
      "text": "Expiration",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Expiration",
      "autoResize": true,
