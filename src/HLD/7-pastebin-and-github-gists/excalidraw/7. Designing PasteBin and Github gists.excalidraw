    {
      "id": "BXea9Eq3TU1QUk1mo-ZIS",
      "type": "text",
      "x": 1986.0410954330496,
      "y": 41936.59684686724,
      "width": 550,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bNa",
      "roundness": null,
      "seed": 1614208124,
      "version": 197,
      "versionNonce": 838441921,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776908618836,
      "link": null,
      "locked": false,
      "text": "Note: \n- Stats DB is sharded by user who created the URL.\n- Aggregations are mostly per user and we leverage\ngrafana to render them.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Note: \n- Stats DB is sharded by user who created the URL.\n- Aggregations are mostly per user and we leverage\ngrafana to render them.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "5QUAxlTCxhlHK-Gi15LnH",
      "type": "text",
      "x": 1969.8098187896744,
      "y": 42159.888636427706,
      "width": 492.7998046875,
      "height": 35,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bNc",
      "roundness": null,
      "seed": 608990972,
      "version": 349,
      "versionNonce": 953138383,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776908618836,
      "link": null,
      "locked": false,
      "text": "How is short_code/url generated?",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "How is short_code/url generated?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "F9rLVVvf7BSCD_XrNPNfi",
      "type": "text",
      "x": 2015.1519307283584,
      "y": 42234.680010998425,
      "width": 572,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bNd",
      "roundness": null,
      "seed": 312827516,
      "version": 271,
      "versionNonce": 1253211041,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776908618836,
      "link": null,
      "locked": false,
      "text": "- If we go one by one, easy to perdict the next one.\n- Generating random integer is prone to collision\n    Here we have to do it uniquely pseudo random\n- Only one maching should not be hanlding this\n    Too much overload on one machine",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- If we go one by one, easy to perdict the next one.\n- Generating random integer is prone to collision\n    Here we have to do it uniquely pseudo random\n- Only one maching should not be hanlding this\n    Too much overload on one machine",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Jj57fqge3soECQIOBJX3n",
      "type": "text",
      "x": 2009.9409514213633,
      "y": 42418.081733890256,
      "width": 561,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bNe",
      "roundness": null,
      "seed": 236328013,
      "version": 89,
      "versionNonce": 2127871695,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776908620916,
      "link": null,
      "locked": false,
      "text": "We leverage partitioning, sharding and transactions\nto achieve this.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We leverage partitioning, sharding and transactions\nto achieve this.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "WhlG0orN28ZKB07_LR7wy",
      "type": "text",
      "x": 2818.9901740110804,
      "y": 42261.66527587054,
      "width": 253,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bNf",
      "roundness": null,
      "seed": 737043715,
      "version": 66,
      "versionNonce": 1283279599,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776908618836,
      "link": null,
      "locked": false,
      "text": "100M / 30 = 3 M per day\n= 125k per hour\n= 2K per minute",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "100M / 30 = 3 M per day\n= 125k per hour\n= 2K per minute",
      "autoResize": true,
      "lineHeight": 1.25
    },
