      "boundElements": [],
      "updated": 1776908603479,
      "link": null,
      "locked": false,
      "text": "Total unique character in short url = (a-z) + (A-Z) + (0-9)\n                                    = 26 + 26 + 10 = 62\nwe define the map that maps\neach of 6 bit to a character        = 2^6.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Total unique character in short url = (a-z) + (A-Z) + (0-9)\n                                    = 26 + 26 + 10 = 62\nwe define the map that maps\neach of 6 bit to a character        = 2^6.",
      "autoResize": true,
      "lineHeight": 1.25
    },
