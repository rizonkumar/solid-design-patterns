    {
      "id": "7SR27JY0Gwx73-q7iKBoA",
      "type": "text",
      "x": 2053.654800424287,
      "y": 43745.54892222803,
      "width": 451,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bOL",
      "roundness": null,
      "seed": 543020963,
      "version": 245,
      "versionNonce": 1272840751,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776908623327,
      "link": null,
      "locked": false,
      "text": "TRANSACTION\n  SELECT * FROM ranges\n  WHERE ID = xxx\n  UPDATE ranges SET current = current + 1\n  WHERE ID = xxx\nCOMMIT",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "TRANSACTION\n  SELECT * FROM ranges\n  WHERE ID = xxx\n  UPDATE ranges SET current = current + 1\n  WHERE ID = xxx\nCOMMIT",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "fvHC3XOTVnHUwqxDtjLco",
      "type": "text",
      "x": 2519.3843573262375,
      "y": 43746.00723175371,
      "width": 561,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bON",
      "roundness": null,
      "seed": 1684072643,
      "version": 220,
      "versionNonce": 1788722241,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776908623327,
      "link": null,
      "locked": false,
      "text": "If range is exhausted, server remove the range (id)\nfrom it's in-memo store(table)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If range is exhausted, server remove the range (id)\nfrom it's in-memo store(table)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "C91iFGiu2j_FCmTwMXMyy",
      "type": "text",
      "x": 2057.252530200884,
      "y": 43924.88085653181,
      "width": 319,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bOO",
      "roundness": null,
      "seed": 1463763011,
      "version": 279,
      "versionNonce": 1683743823,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776908623327,
      "link": null,
      "locked": false,
      "text": "So for eg. in ID = 2,\ncurrent will be 250 + 1 = 251",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "So for eg. in ID = 2,\ncurrent will be 250 + 1 = 251",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "2YdMD0BZnV_ZCa-9QIU_p",
      "type": "text",
      "x": 2064.5763164212694,
      "y": 44017.73307743926,
      "width": 814,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bOP",
      "roundness": null,
      "seed": 202860237,
      "version": 251,
      "versionNonce": 184454177,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776908623327,
      "link": null,
      "locked": false,
      "text": "Because we are picking one random range, we see a pseudorandom order\nwithtin range the order is sequential.\nNow once we have the \"random_id\", we encode and store mapping of short_url\nand original in the URL DB.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Because we are picking one random range, we see a pseudorandom order\nwithtin range the order is sequential.\nNow once we have the \"random_id\", we encode and store mapping of short_url\nand original in the URL DB.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "G1OeqD6I0sXiCmebbLWRn",
      "type": "text",
      "x": 2056.5185832402117,
      "y": 44185.32670223827,
      "width": 1324.1640625,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bOc",
      "roundness": null,
      "seed": 861434051,
      "version": 85,
      "versionNonce": 470697071,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776908625179,
      "link": null,
      "locked": false,
      "text": "We take max ids we would support, say 4 Billion (≈ 2³²) at 100M per month consumption, it would take 40 months ≈ 3 years\nto exhaust the range.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We take max ids we would support, say 4 Billion (≈ 2³²) at 100M per month consumption, it would take 40 months ≈ 3 years\nto exhaust the range.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "dk1NNqzjCe5j-0MM5SOGv",
      "type": "text",
      "x": 2060.584440452586,
      "y": 44282.22250215778,
      "width": 847,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bOd",
      "roundness": null,
      "seed": 1308232781,
      "version": 52,
      "versionNonce": 641318401,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776908625179,
      "link": null,
      "locked": false,
      "text": "if we want to support more, we increase int to 64 bits giving us a range till\n2⁶⁴ = 1.84 × 10¹⁹\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "if we want to support more, we increase int to 64 bits giving us a range till\n2⁶⁴ = 1.84 × 10¹⁹\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "lyl62yDmNodw70JFvzXRI",
      "type": "text",
      "x": 2058.9711909221887,
      "y": 44359.34682913941,
      "width": 1007.24609375,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bOe",
      "roundness": null,
      "seed": 896502371,
      "version": 126,
      "versionNonce": 1103748751,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776908625179,
      "link": null,
      "locked": false,
      "text": "and it would take\n2⁶⁴ = 1.84 × 10¹⁹ / (100 × 10⁶)\n= 1.84 × 10¹¹ months ≈ 0.1533 × 10¹¹ years ≈ 15.3 billion years - So we are compeletly sage",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "and it would take\n2⁶⁴ = 1.84 × 10¹⁹ / (100 × 10⁶)\n= 1.84 × 10¹¹ months ≈ 0.1533 × 10¹¹ years ≈ 15.3 billion years - So we are compeletly sage",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "-0cw_Tx5rzV-4AZfHeiQw",
      "type": "text",
      "x": 2055.6177488650337,
      "y": 44482.56334511879,
      "width": 464.08203125,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bOf",
      "roundness": null,
      "seed": 697379501,
      "version": 68,
      "versionNonce": 2134136289,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776908625179,
      "link": null,
      "locked": false,
      "text": "64 bit number ≈ 66 bit ≈ 11 char (encoded)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "64 bit number ≈ 66 bit ≈ 11 char (encoded)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "zqBKypupSsNubskTpMNGJ",
      "type": "text",
      "x": 2057.1643462050815,
      "y": 44557.59319756806,
      "width": 770,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bOg",
      "roundness": null,
      "seed": 578380067,
      "version": 268,
      "versionNonce": 2102211759,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776908625179,
      "link": null,
      "locked": false,
      "text": "But if we want to restrict the short code length, just reduce the bit.\nAlso instead of starting from 0, lets do it from 100,000 to have\nshort code of length at least 3.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "But if we want to restrict the short code length, just reduce the bit.\nAlso instead of starting from 0, lets do it from 100,000 to have\nshort code of length at least 3.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ynHsbXu33bx-kBXz888ua",
      "type": "text",
      "x": 2055.6123549858526,
      "y": 44664.65387310199,
      "width": 572,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bOh",
      "roundness": null,
      "seed": 1248873699,
      "version": 89,
      "versionNonce": 818999745,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776908625179,
      "link": null,
      "locked": false,
      "text": "Say, we want short code minLength = 3, maxLength = 8",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Say, we want short code minLength = 3, maxLength = 8",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "6xGi4-wjQsksw9B-OlnY-",
      "type": "text",
      "x": 2066.923434079664,
      "y": 44732.64194291089,
      "width": 187,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bOi",
      "roundness": null,
      "seed": 1392175299,
      "version": 18,
      "versionNonce": 910214863,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776908625179,
      "link": null,
      "locked": false,
      "text": "min len = 3\n= 3 char\n= 3 × 6 = 18 bits\n= 2¹⁸ ≈ 100,000",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "min len = 3\n= 3 char\n= 3 × 6 = 18 bits\n= 2¹⁸ ≈ 100,000",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "i1RrhiJFbrT2-Qe3K1wVj",
      "type": "text",
      "x": 2048.8522894820553,
      "y": 44877.628161360124,
      "width": 484,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bOj",
      "roundness": null,
      "seed": 1649813421,
      "version": 193,
      "versionNonce": 1613697441,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776908625179,
      "link": null,
      "locked": false,
      "text": "Say we want each range to exhause in 1 year.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Say we want each range to exhause in 1 year.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "JK5oYWnS1zTEehmsjdp7z",
      "type": "text",
      "x": 2365.3287662506755,
      "y": 44734.14061505986,
      "width": 214.205078125,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
