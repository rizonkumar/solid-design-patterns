    {
      "id": "zucaTszi1YLErsEAUBdyR",
      "type": "text",
      "x": 1939.0238529079495,
      "y": 39589.38817897465,
      "width": 737,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bM3",
      "roundness": null,
      "seed": 1115573372,
      "version": 156,
      "versionNonce": 1221748271,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776908609180,
      "link": null,
      "locked": false,
      "text": "When someone visits the URL, the request comes to our API\nserver we get the actual URL from the shard, we return 301 redirect\nwith this URL.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When someone visits the URL, the request comes to our API\nserver we get the actual URL from the shard, we return 301 redirect\nwith this URL.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "qH5yKT58KmqjHCuvSR8-H",
