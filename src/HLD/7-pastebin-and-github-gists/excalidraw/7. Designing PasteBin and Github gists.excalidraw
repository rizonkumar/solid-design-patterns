    },
    {
      "id": "eFmsYGRIMhgZize6NR78V",
      "type": "text",
      "x": 2255.405453794924,
      "y": 51071.984764863504,
      "width": 1133,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bSB",
      "roundness": null,
      "seed": 655552545,
      "version": 511,
      "versionNonce": 995138383,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776648450572,
      "link": null,
      "locked": false,
      "text": "- Owner of the file can set expiration to a file, which it becomes inaccessible and eventually deleted.\n- we add \"expiration\" column.\n- when file is accessed, we first check expiration time.\n  if beyond: return 404\n  else: fetch and return\n- Run a simple cleanup job that cleans the expired files from the Meta DB and S3.\n- Make it runs once a day. (FIG 1.3)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Owner of the file can set expiration to a file, which it becomes inaccessible and eventually deleted.\n- we add \"expiration\" column.\n- when file is accessed, we first check expiration time.\n  if beyond: return 404\n  else: fetch and return\n- Run a simple cleanup job that cleans the expired files from the Meta DB and S3.\n- Make it runs once a day. (FIG 1.3)",
      "autoResize": true,
      "lineHeight": 1.25
    },
