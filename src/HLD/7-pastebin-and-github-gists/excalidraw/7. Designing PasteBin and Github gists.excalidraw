      "versionNonce": 1262294255,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776908625179,
      "link": null,
      "locked": false,
      "text": "max len = 8\n= 8 char\n= 8 × 6 = 48 bits\n= 2⁴⁸ ≈ 5.62 × 10¹⁴",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "max len = 8\n= 8 char\n= 8 × 6 = 48 bits\n= 2⁴⁸ ≈ 5.62 × 10¹⁴",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
