      "boundElements": null,
      "updated": 1776647797806,
      "link": null,
      "locked": false,
      "text": "The FLOW\n- So the request comes to the API Server\n- the API Server extract the UUID.\n- It goes to the META DB and get the entry\nand knows the owner of the file\n- Then it goes to the S3 and check if the file exist.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The FLOW\n- So the request comes to the API Server\n- the API Server extract the UUID.\n- It goes to the META DB and get the entry\nand knows the owner of the file\n- Then it goes to the S3 and check if the file exist.",
      "autoResize": true,
      "lineHeight": 1.25
    },
