      "versionNonce": 1309161645,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776306665529,
      "link": null,
      "locked": false,
      "text": "To start with, we create these 1M entries in DB\nand upon getting request, pick one range\nat random & get one int out of it.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "To start with, we create these 1M entries in DB\nand upon getting request, pick one range\nat random & get one int out of it.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "vtAGyOZSa9FlI7Zb_nsNc",
      "type": "text",
      "x": 2065.901403837394,
      "y": 45393.05021502749,
      "width": 671,
      "height": 75,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bOw",
      "roundness": null,
      "seed": 19594189,
      "version": 95,
      "versionNonce": 445673069,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776307010438,
      "link": null,
      "locked": false,
      "text": "If one DB becomes a bottleneck, we spin up a new DB and move\nsome ranges there. Now API server will pick one ticket server\nat random. - FIG 1.4",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If one DB becomes a bottleneck, we spin up a new DB and move\nsome ranges there. Now API server will pick one ticket server\nat random. - FIG 1.4",
      "autoResize": true,
      "lineHeight": 1.25
    },
