    },
    {
      "id": "F9rLVVvf7BSCD_XrNPNfi",
      "type": "text",
      "x": 2015.1519307283584,
      "y": 42234.680010998425,
      "width": 572,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bNd",
      "roundness": null,
      "seed": 312827516,
      "version": 270,
      "versionNonce": 1640051747,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776304887410,
      "link": null,
      "locked": false,
      "text": "- If we go one by one, easy to perdict the next one.\n- Generating random integer is prone to collision\n    Here we have to do it uniquely pseudo random\n- Only one maching should not be hanlding this\n    Too much overload on one machine",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- If we go one by one, easy to perdict the next one.\n- Generating random integer is prone to collision\n    Here we have to do it uniquely pseudo random\n- Only one maching should not be hanlding this\n    Too much overload on one machine",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Jj57fqge3soECQIOBJX3n",
      "type": "text",
      "x": 2009.9409514213633,
      "y": 42418.081733890256,
      "width": 561,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bNe",
      "roundness": null,
      "seed": 236328013,
      "version": 88,
      "versionNonce": 1633726765,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776304943032,
      "link": null,
      "locked": false,
      "text": "We leverage partitioning, sharding and transactions\nto achieve this.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We leverage partitioning, sharding and transactions\nto achieve this.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "WhlG0orN28ZKB07_LR7wy",
      "type": "text",
      "x": 2818.9901740110804,
      "y": 42261.66527587054,
      "width": 253,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bNf",
