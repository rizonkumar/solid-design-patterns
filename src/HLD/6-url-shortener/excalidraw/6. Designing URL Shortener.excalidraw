      "isDeleted": false,
      "boundElements": [],
      "updated": 1776178098807,
      "link": null,
      "locked": false,
      "text": "How is short_code/url generated?",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "How is short_code/url generated?",
