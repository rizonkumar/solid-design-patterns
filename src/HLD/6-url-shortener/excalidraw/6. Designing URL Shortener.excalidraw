    {
      "id": "zucaTszi1YLErsEAUBdyR",
      "type": "text",
      "x": 1939.0238529079495,
      "y": 39589.38817897465,
      "width": 737,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
