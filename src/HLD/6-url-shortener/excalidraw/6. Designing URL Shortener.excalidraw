    },
    {
      "id": "bemquSEBizwQ_x7fmuM9h",
      "type": "text",
      "x": 2298.232251690951,
      "y": 45265.42461818933,
      "width": 517,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
