      "text": "- 100K to 1200M\n- 1200M to 2400M\n- 2400M to 3600M",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- 100K to 1200M\n- 1200M to 2400M\n- 2400M to 3600M",
      "autoResize": true,
