      "versionNonce": 1373462524,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776140269312,
      "link": null,
      "locked": false,
      "text": "Note: \n- Stats DB is sharded by user who created the URL.\n- Aggregations are mostly per user and we leverage\ngrafana to render them.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Note: \n- Stats DB is sharded by user who created the URL.\n- Aggregations are mostly per user and we leverage\ngrafana to render them.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "5QUAxlTCxhlHK-Gi15LnH",
      "type": "text",
