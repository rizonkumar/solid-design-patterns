      "versionNonce": 314709485,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776304959153,
      "link": null,
      "locked": false,
      "text": "100M / 30 = 3 M per day\n= 125k per hour\n= 2K per minute",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "100M / 30 = 3 M per day\n= 125k per hour\n= 2K per minute",
      "autoResize": true,
      "lineHeight": 1.25
    },
