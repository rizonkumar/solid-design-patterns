    {
      "id": "NIzRPfE9i9mYJb_dUIeW9",
      "type": "text",
      "x": 1492.9100288864302,
      "y": 3597.34330751882,
      "width": 374,
      "height": 50,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
