    {
      "id": "8xBs5-mmfp_nlOcCckkNw",
      "type": "text",
      "x": 27.05078125,
      "y": 877.0350341796875,
      "width": 843.1195068359375,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aN",
      "roundness": null,
      "seed": 1988272101,
      "version": 42,
      "versionNonce": 76356932,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775403927770,
      "link": null,
      "locked": false,
      "text": "Tech Stack: The project utilizes Express for the API, Drizzle ORM with PostgreSQL \nfor database management, Next.js for the frontend, and Zod for schema validation.\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Tech Stack: The project utilizes Express for the API, Drizzle ORM with PostgreSQL \nfor database management, Next.js for the frontend, and Zod for schema validation.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "8TdTdXtqAiBLxsRGVobrj",
      "type": "text",
      "x": 34,
      "y": 968.3018798828125,
      "width": 335.77972412109375,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aO",
      "roundness": null,
      "seed": 462317765,
      "version": 10,
      "versionNonce": 743524604,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775403927770,
      "link": null,
      "locked": false,
      "text": "high-level architectural design flow\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "high-level architectural design flow\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "j33P7GKfaSz-loGTT4Qti",
      "type": "text",
      "x": 43.90996133585688,
      "y": 1015.4468278926461,
      "width": 1299.4591064453125,
      "height": 325,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aP",
      "roundness": null,
      "seed": 1448865515,
      "version": 395,
      "versionNonce": 1929434308,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775403927770,
      "link": null,
      "locked": false,
      "text": "1. API Server: Acts as the HTTP entry point for receiving raw video uploads.\n\n2. Job Queue: Once the video is received by the API, it is pushed into a job queue to handle the processing tasks asynchronously.\n\n3. Worker Distribution: The job queue distributes these tasks among a pool of three workers.\n\n4. Processing Stages: Each worker is responsible for specific tasks, including:\n\n5. Transcoding: Converting the raw video into multiple qualities: 360p, 720p, and 1080p.\n\n6. Thumbnail Generation: Creating both standard thumbnails and timestamped preview thumbnails for a better seeking experience.\n\n7. HLS Integration: Generating the HLS (HTTP Live Streaming) master playlists and segments for smooth, production-ready playback.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. API Server: Acts as the HTTP entry point for receiving raw video uploads.\n\n2. Job Queue: Once the video is received by the API, it is pushed into a job queue to handle the processing tasks asynchronously.\n\n3. Worker Distribution: The job queue distributes these tasks among a pool of three workers.\n\n4. Processing Stages: Each worker is responsible for specific tasks, including:\n\n5. Transcoding: Converting the raw video into multiple qualities: 360p, 720p, and 1080p.\n\n6. Thumbnail Generation: Creating both standard thumbnails and timestamped preview thumbnails for a better seeking experience.\n\n7. HLS Integration: Generating the HLS (HTTP Live Streaming) master playlists and segments for smooth, production-ready playback.",
      "autoResize": true,
      "lineHeight": 1.25
    },
