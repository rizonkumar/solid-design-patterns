    },
    {
      "id": "3a6QmkhnjHSG0bXUVN1fT",
      "type": "text",
      "x": 1502.1484340855302,
      "y": 3712.1869834147637,
      "width": 759,
      "height": 275,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2V",
      "roundness": null,
      "seed": 71439228,
      "version": 652,
      "versionNonce": 1996861692,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775406230961,
      "link": null,
      "locked": false,
      "text": "Note: \n1. The master can do write or read \nthere is no such rule, same for the\nreplica\n2. How backend will have two DB?\nso we will have two connection string\nfor read we will use replica string connection.\n3. We might add caching in the read, instead of read replica\nbut here we choose to go with read replica route, as in case of cache\nlet say if one of the Product price is changed then we need to udpate\nour cache and cache validaion is needed this is caching route.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Note: \n1. The master can do write or read \nthere is no such rule, same for the\nreplica\n2. How backend will have two DB?\nso we will have two connection string\nfor read we will use replica string connection.\n3. We might add caching in the read, instead of read replica\nbut here we choose to go with read replica route, as in case of cache\nlet say if one of the Product price is changed then we need to udpate\nour cache and cache validaion is needed this is caching route.",
      "autoResize": true,
      "lineHeight": 1.25
    },
