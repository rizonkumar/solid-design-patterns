      "boundElements": null,
      "updated": 1775440425695,
      "link": null,
      "locked": false,
      "text": "“Product is the central entity. Each product belongs to one category,\nand a category can have many products. A product can have multiple\nimages and variants, so I’ve kept those in separate tables to maintain\nnormalization and flexibility.”",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "“Product is the central entity. Each product belongs to one category, and a category can have many products. A product can have multiple images and variants, so I’ve kept those in separate tables to maintain normalization and flexibility.”",
      "autoResize": false,
      "lineHeight": 1.25
    }
