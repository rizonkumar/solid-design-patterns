      "roundness": null,
      "seed": 1902270542,
      "version": 227,
      "versionNonce": 817740110,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775529948377,
      "link": null,
      "locked": false,
      "text": "Design a notification service that send notificatons to users across channel. The system needs to be horizontally scalbale and should support\na very high fan-out.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Design a notification service that send notificatons to users across channel. The system needs to be horizontally scalbale and should support\na very high fan-out.",
      "autoResize": true,
      "lineHeight": 1.25
    },
