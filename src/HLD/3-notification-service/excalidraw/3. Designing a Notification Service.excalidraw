      "seed": 1212747214,
      "version": 215,
      "versionNonce": 1980707790,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775530291382,
      "link": null,
      "locked": false,
      "text": "When any team/product want to send notification\n\n1. Create a template using the Notificaiton Control Service.\n2. Specify the variable\n3. Note the ID of the defined template.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When any team/product want to send notification\n\n1. Create a template using the Notificaiton Control Service.\n2. Specify the variable\n3. Note the ID of the defined template.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "qnbkWA5-dkJk_FFWJ8-M2",
      "type": "text",
      "x": 1582.6736624750117,
      "y": 14714.586773499905,
      "width": 323.3998718261719,
      "height": 35,
