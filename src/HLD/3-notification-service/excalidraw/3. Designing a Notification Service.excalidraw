    },
    {
      "id": "GCRT09Q5vta6KrHAD606L",
      "type": "text",
      "x": 1578.5818818023652,
      "y": 14815.203655297202,
      "width": 462,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6u",
      "roundness": null,
      "seed": 1467932498,
      "version": 99,
      "versionNonce": 38974482,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775530340863,
      "link": null,
      "locked": false,
      "text": "User can be notified via multipl channels ",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "User can be notified via multipl channels ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ElnBGSUvJ-rB7Nt48aaT5",
      "type": "text",
      "x": 1589.2754347817524,
      "y": 14865.452918886527,
      "width": 308,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6v",
      "roundness": null,
      "seed": 224535182,
      "version": 77,
      "versionNonce": 1725894030,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775530367133,
      "link": null,
      "locked": false,
      "text": "1. email\n2. android push notification\n3. apple push notification\n4. SMS",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. email\n2. android push notification\n3. apple push notification\n4. SMS",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "THkCZG13fP-gda-RgCIVy",
      "type": "text",
      "x": 1963.28066523084,
      "y": 14882.325335297764,
      "width": 880,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6w",
      "roundness": null,
      "seed": 231215182,
      "version": 153,
      "versionNonce": 1620584014,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775530402815,
      "link": null,
      "locked": false,
      "text": "For each of these channels there are providers that exposes APIs, we invoke them\nprogrammatically to send notification at the very instant.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "For each of these channels there are providers that exposes APIs, we invoke them\nprogrammatically to send notification at the very instant.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "NWfxqdomOCS6CxZIWtt9f",
      "type": "text",
      "x": 1576.6211224733247,
      "y": 15051.049499410135,
      "width": 1166,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6x",
      "roundness": null,
      "seed": 532545234,
      "version": 185,
      "versionNonce": 1036959954,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775530458891,
      "link": null,
      "locked": false,
      "text": "Some example: SES, Mailgun, OneSignal, Twilio, msg91 etc\nSo, the servers that will send/trigger the actual notification will have to configure their SDKs/libaries.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Some example: SES, Mailgun, OneSignal, Twilio, msg91 etc\nSo, the servers that will send/trigger the actual notification will have to configure their SDKs/libaries.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "XisC5bD3OVwpTlUYJ_oSF",
      "type": "text",
      "x": 1576.6211224733247,
      "y": 15148.681033956407,
      "width": 1386,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6y",
      "roundness": null,
      "seed": 847763986,
      "version": 154,
      "versionNonce": 869940814,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775530502623,
      "link": null,
      "locked": false,
      "text": "Note: THe API call are expensive network call with high latencies, one maching will not be able to make millions of concurrent\nnetwork calls",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Note: THe API call are expensive network call with high latencies, one maching will not be able to make millions of concurrent\nnetwork calls",
      "autoResize": true,
      "lineHeight": 1.25
    },
