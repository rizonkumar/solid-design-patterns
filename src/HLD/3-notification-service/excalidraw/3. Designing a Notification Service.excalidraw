      "isDeleted": false,
      "boundElements": null,
      "updated": 1775614022220,
      "link": null,
      "locked": false,
      "text": "It is really irritating to receive marketng notifications and it's the worst if we receive multiple of the same\ncampaign.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It is really irritating to receive marketng notifications and it's the worst if we receive multiple of the same\ncampaign.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "H2HfrkDkCc0Uw_PVeYhNj",
      "type": "text",
      "x": 1430.3935135759411,
      "y": 19558.85871088169,
      "width": 1166,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bBa",
      "roundness": null,
      "seed": 901099003,
      "version": 220,
      "versionNonce": 1740480373,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775614257895,
      "link": null,
      "locked": false,
      "text": "To ensure we do not accidentally send multiple notification from same campaign we keep track in a database\n(KV store is fine), fig 1.6",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "To ensure we do not accidentally send multiple notification from same campaign we keep track in a database\n(KV store is fine), fig 1.6",
      "autoResize": true,
      "lineHeight": 1.25
    },
