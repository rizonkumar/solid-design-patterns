    {
      "id": "2OPXJT0VcdiyjdBkU5ibv",
      "type": "text",
      "x": 1488.0629056065386,
      "y": 18163.578150113302,
      "width": 528,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
