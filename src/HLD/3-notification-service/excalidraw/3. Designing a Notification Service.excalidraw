      "updated": 1775615014097,
      "link": null,
      "locked": false,
      "text": "We can make Rate limiter having its own load balancer\nand a bunch of API Servers.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We can make Rate limiter having its own load balancer\nand a bunch of API Servers.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ahT1h3B2sjZOjpqfK5rVW",
      "type": "text",
      "x": 1473.2960120765,
      "y": 7481.641549140382,
      "width": 583,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4F",
      "roundness": null,
      "seed": 1708538236,
      "version": 129,
      "versionNonce": 1179022299,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775615014097,
      "link": null,
      "locked": false,
      "text": "But this adds substantial network hops. Nothing\nwrong in this just be aware of the trade off. fig 1.1",
