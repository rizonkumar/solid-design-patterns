      "link": null,
      "locked": false,
      "text": "What if PM wants to triggers thousands of notification at the same time",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What if PM wants to triggers thousands of notification at the same time",
