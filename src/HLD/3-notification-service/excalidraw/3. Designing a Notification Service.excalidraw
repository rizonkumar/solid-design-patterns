    },
    {
      "id": "36vft-RKybXnRED7KL2Q9",
      "type": "text",
      "x": 1572.4030183705154,
      "y": 15927.769118295639,
      "width": 957,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b7Q",
      "roundness": null,
      "seed": 515459150,
      "version": 215,
      "versionNonce": 719012370,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775533641442,
      "link": null,
      "locked": false,
      "text": "- Triggering one notification for every uses is a pain for PM.\n- Controler Service becomes the bottleneck (network call takes time) + provider outage?",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Triggering one notification for every uses is a pain for PM.\n- Controler Service becomes the bottleneck (network call takes time) + provider outage?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "L2frM7RReOlKrtCtEycAW",
      "type": "text",
