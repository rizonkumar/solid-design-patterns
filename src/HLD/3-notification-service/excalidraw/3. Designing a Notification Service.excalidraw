    {
      "id": "0UyAyiLgJptkukQOLnRsM",
      "type": "text",
      "x": 1503.9424153759167,
      "y": 5347.06266554793,
      "width": 946,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b38",
      "roundness": null,
      "seed": 1044198852,
      "version": 131,
      "versionNonce": 430794587,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775615006592,
      "link": null,
      "locked": false,
      "text": "System break down under the termendous load and we need to ensure that doesn't happen.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "System break down under the termendous load and we need to ensure that doesn't happen.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "EjHe58qjjOBGbL9pO1td1",
      "type": "text",
      "x": 1514.1288581561153,
      "y": 5411.845239583078,
      "width": 649,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b39",
      "roundness": null,
      "seed": 761087172,
      "version": 256,
      "versionNonce": 801345493,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775615006592,
      "link": null,
      "locked": false,
      "text": "Design a rate limiter such that\n- limit the number of request in a given period.\n- allow developer to configure threshold at granular level.\n- doesn't add a massive additional overhead. ",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Design a rate limiter such that\n- limit the number of request in a given period.\n- allow developer to configure threshold at granular level.\n- doesn't add a massive additional overhead. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "0aDl5Tb63dIfw_QryFIU0",
      "type": "text",
