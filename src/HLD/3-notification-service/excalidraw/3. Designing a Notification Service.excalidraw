      "versionNonce": 708321998,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775534594581,
      "link": null,
      "locked": false,
      "text": "We need a UI and simple backend to create a notification templates that will be configured by some internal team.\nNumber of notificaion template will no be huge and will fit on a single machine.\nHence we start relational DB. (FG 1.1)",
      "fontSize": 20,
      "fontFamily": 8,
