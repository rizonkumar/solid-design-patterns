    {
      "id": "WFjRalgdMcqKvZ3tFchPY",
      "type": "text",
      "x": 1354.1326080192916,
      "y": 20809.23874530973,
      "width": 748,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
