    {
      "id": "MXNgSSH7IZzaONnm3l3d3",
      "type": "text",
      "x": 1518.5580557490769,
      "y": 5635.530213756532,
      "width": 693,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3C",
      "roundness": null,
      "seed": 1573788484,
      "version": 208,
      "versionNonce": 1020054837,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775615006592,
      "link": null,
      "locked": false,
      "text": "- First line of defence.\n- Any incoming request is first consulted against rate limiter.\n- if we are under limits, go throught \n- otherwise, reject with error [429]. ",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- First line of defence.\n- Any incoming request is first consulted against rate limiter.\n- if we are under limits, go throught \n- otherwise, reject with error [429]. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
