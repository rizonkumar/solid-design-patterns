    {
      "id": "Qf6508tzD_ZYY0VI9vzSh",
      "type": "text",
      "x": 1582.7285857055174,
      "y": 13828.192525598846,
      "width": 1551,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
